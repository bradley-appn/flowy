{
    "compileOnSave": true,
    "compilerOptions": {
        "noImplicitAny": false,
        "noEmitOnError": true,
        "removeComments": true,
        "allowUnreachableCode": false,
        "newLine": "LF",
        "sourceMap": true,
        "target": "es6",
        "strict": true,
        "module": "system",
        "moduleResolution": "node",
        "typeRoots": [ "../node_modules/@types" ],
        "skipLibCheck": true
    },
    "exclude": [
        "../node_modules"
    ]
}
